# ==========================================
# Campus2Career - Environment Configuration
# ==========================================
# IMPORTANT: Never commit .env file to version control
# Copy this file to .env and fill in your actual values
# ==========================================

# ── Supabase Configuration (Primary Database & Auth) ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service Role Key - ONLY for server-side scripts (NEVER expose in frontend)
# This should be in a separate .env.server file for backend operations
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── AI Provider Configuration ──
# OpenRouter API key goes in Railway environment variables ONLY (server-side)
# NEVER put it here — it would be exposed in the browser bundle
# Set OPENROUTER_API_KEY in Railway dashboard → Variables

# Python AI Backend (proxies all AI calls — keeps API key secure)
VITE_AI_BACKEND_URL=https://rachit10-campus2career.hf.space

# ── Code Execution API ──
VITE_JUDGE0_API_KEY=your_judge0_rapidapi_key_here
VITE_JUDGE0_BASE_URL=https://judge0-ce.p.rapidapi.com
VITE_JUDGE0_HOST=judge0-ce.p.rapidapi.com

# ── Application Configuration ──
# Environment: 'development' | 'staging' | 'production'
VITE_APP_ENV=development

# Demo/mock login must stay disabled in production unless deliberately enabled
VITE_ENABLE_DEMO_LOGIN=false

# API Rate Limiting (requests per minute)
VITE_AI_RATE_LIMIT=30
VITE_API_RATE_LIMIT=100

# ── Monitoring & Analytics (Optional) ──
VITE_SENTRY_DSN=your_sentry_dsn_here
VITE_POSTHOG_API_KEY=your_posthog_api_key_here
